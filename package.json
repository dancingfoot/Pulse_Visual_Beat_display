{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "description": "Pulse Link Network Sync Client & Metronome",
  "author": "dancingfoot@gmail.com",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist dist-desktop",
    "lint": "tsc --noEmit",
    "postinstall": "node patch-abletonlink.cjs && node -e \"try { require('child_process').execSync('electron-builder install-app-deps', { stdio: 'inherit' }); } catch (e) { console.log('electron-builder not found or failed, skipping app-deps installation.'); }\"",
    "desktop:install": "npm install --ignore-scripts && node patch-abletonlink.cjs && npm rebuild",
    "desktop:dev": "npm run build && electron .",
    "desktop:rebuild": "electron-rebuild",
    "desktop:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
